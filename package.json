{
  "name": "open-multi-agent-kit",
  "version": "1.1.18",
  "description": "Provider-neutral agent runtime for coding workflows. Verified DAG execution with evidence gates, worktree isolation, and local graph memory.",
  "type": "module",
  "bin": {
    "omk": "dist/cli.js",
    "open-multi-agent-kit": "dist/cli.js",
    "omk-project-mcp": "dist/mcp/omk-project-server.js",
    "omk-acp": "dist/mcp/acp-server.js",
    "omk-mcp-host": "dist/mcp/host.js"
  },
  "scripts": {
    "clean:dist": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc && node scripts/chmod-dist.mjs",
    "build:clean": "npm run clean:dist && npm run build",
    "dev": "tsx src/cli.ts",
    "lint": "node node_modules/eslint/bin/eslint.js --max-warnings=0 src/",
    "check": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs",
    "secret:scan": "node scripts/secret-scan.mjs",
    "secret:scan:runtime": "node scripts/secret-scan.mjs --runtime",
    "verify": "npm run yaml:check && npm run lint && npm run secret:scan && npm run secret:scan:runtime && npm run check && npm run build:clean && npm run test",
    "pack:dry": "node scripts/pack-dry.mjs",
    "audit:package": "node scripts/package-audit.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "smoke:pack": "node scripts/pack-smoke.mjs",
    "prepare": "npm run build",
    "yaml:check": "node scripts/validate-yaml.mjs",
    "release:check": "npm run verify && npm run native:build && npm run pack:dry && npm run audit:package && npm run smoke:pack",
    "smoke:no-kimi:chat": "KIMI_BIN=/nonexistent/kimi OMK_LEGACY_CHAT=0 OMK_MCP_PREFLIGHT=off OMK_PROJECT_ROOT=\"$PWD\" node dist/cli.js chat --provider auto --mode agent --execution ask --layout plain --mcp-scope none --smoke --json",
    "smoke:no-kimi:codex": "KIMI_BIN=/nonexistent/kimi OMK_LEGACY_CHAT=0 OMK_MCP_PREFLIGHT=off OMK_PROJECT_ROOT=\"$PWD\" node dist/cli.js chat --provider codex --mode agent --execution ask --layout plain --mcp-scope none --smoke --json",
    "smoke:no-kimi:doctor": "KIMI_BIN=/nonexistent/kimi OMK_LEGACY_CHAT=0 OMK_PROJECT_ROOT=\"$PWD\" node dist/cli.js doctor --json",
    "verify:no-kimi": "npm run build:clean && npm run smoke:no-kimi:doctor && npm run smoke:no-kimi:chat && npm run smoke:no-kimi:codex",
    "rust:check": "node scripts/rust-safety-check.mjs",
    "rust:build": "cargo build -p omk-safety",
    "native:build": "node scripts/build-native.mjs",
    "native:normalize": "node scripts/normalize-native-artifacts.mjs"
  },
  "keywords": [
    "agent-runtime",
    "provider-neutral",
    "coding-agents",
    "dag-runtime",
    "evidence-gates",
    "multi-agent-orchestration",
    "agent-supervisor",
    "open-multiagent-kit",
    "omk",
    "agent",
    "agent-ensemble",
    "agent-orchestration",
    "agentic-coding",
    "ai",
    "ai-agent",
    "ai-agents",
    "ai-coding",
    "ai-devtools",
    "autonomous-agents",
    "cli",
    "cli-tool",
    "code-assistant",
    "code-generation",
    "code-review-automation",
    "coding",
    "coding-agent",
    "dag",
    "design-md",
    "developer-experience",
    "developer-tools",
    "ensemble",
    "git-worktree",
    "graph-memory",
    "multi-provider",
    "agent-supervisor",
    "codex",
    "claude-code",
    "openrouter",
    "qwen",
    "deepseek",
    "language-server-protocol",
    "large-language-model",
    "llm",
    "local-first",
    "lsp",
    "mcp",
    "model-context-protocol",
    "multi-agent",
    "multi-agent-orchestration",
    "nodejs",
    "orchestration",
    "parallel-execution",
    "quality-gates",
    "scheduler",
    "task-graph",
    "task-scheduler",
    "tmux",
    "typescript",
    "workflow-automation",
    "worktree",
    "yolo-mode"
  ],
  "author": "dmae97",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "commander": "^14.0.0",
    "execa": "^9.0.0",
    "fs-extra": "^11.0.0",
    "node-pty": "^1.1.0",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.1.3",
    "yaml": "^2.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/fs-extra": "^11.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "tsx": "^4.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "files": [
    "dist",
    "templates",
    "docs",
    "readmeasset",
    "CHANGELOG.md",
    "MATURITY.md",
    "README.md",
    "AGENTS.md",
    "SECURITY.md",
    "ROADMAP.md",
    "DESIGN.md",
    "WORKER_MANIFEST.md",
    "CLAUDE.md",
    "GEMINI.md",
    "LICENSE",
    "llms.txt"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dmae97/open_multi-agent_kit.git"
  },
  "bugs": {
    "url": "https://github.com/dmae97/open_multi-agent_kit/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/dmae97/open_multi-agent_kit#readme",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "optionalDependencies": {
    "kuzu": "^0.11.3",
    "playwright": "^1.44.0"
  },
  "overrides": {
    "cmake-js": {
      "tar": "^7.5.13"
    }
  }
}
