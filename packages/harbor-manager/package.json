{
	"type": "module",
	"private": true,
	"name": "@oh-my-pi/harbor-manager",
	"version": "0.0.1",
	"description": "Manage Harbor benchmark runs against the local omp build: CLI runner, SQLite-backed run store, REST/SSE API, and a live web dashboard",
	"homepage": "https://omp.sh",
	"author": "Can Boluk",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/can1357/oh-my-pi.git",
		"directory": "packages/harbor-manager"
	},
	"bin": {
		"harbor-manager": "src/runner.ts"
	},
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"start": "bun run src/runner.ts",
		"serve": "bun run src/server.ts",
		"test": "bun test"
	},
	"dependencies": {
		"clsx": "^2.1.1",
		"d3-scale": "^4.0.2",
		"d3-shape": "^3.2.0",
		"motion": "^12.15.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"tailwind-merge": "^3.3.0"
	},
	"devDependencies": {
		"@types/bun": "catalog:",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.7",
		"@types/react": "^19.1.0",
		"@types/react-dom": "^19.1.0"
	},
	"engines": {
		"bun": ">=1.3.14"
	}
}
