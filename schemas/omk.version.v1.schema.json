{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-multi-agent-kit.dev/schemas/omk.version.v1.schema.json",
  "title": "OMK Version Report",
  "type": "object",
  "required": ["schemaVersion", "packageName", "packageVersion", "runtimeVersion", "schemaVersions", "dirty", "consistent", "mismatches"],
  "properties": {
    "schemaVersion": { "const": "omk.version.v1" },
    "packageName": { "type": "string", "minLength": 1 },
    "packageVersion": { "type": "string", "minLength": 1 },
    "runtimeVersion": { "const": "v1.2" },
    "schemaVersions": { "type": "array", "items": { "type": "string" } },
    "gitCommit": { "type": "string" },
    "gitBranch": { "type": "string" },
    "npmPublishedVersion": { "type": "string" },
    "sourceTarget": { "type": "string" },
    "releaseCandidate": { "type": "string" },
    "dirty": { "type": "boolean" },
    "consistent": { "type": "boolean" },
    "mismatches": { "type": "array" }
  }
}
