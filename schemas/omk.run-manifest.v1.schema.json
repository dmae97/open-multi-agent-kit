{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-multi-agent-kit.dev/schemas/omk.run-manifest.v1.schema.json",
  "title": "OMK Run Manifest",
  "type": "object",
  "required": ["schemaVersion", "runId", "createdAt", "status", "providerPolicy", "nodes", "artifacts", "evidenceSummary"],
  "properties": {
    "schemaVersion": { "const": "omk.run-manifest.v1" },
    "runId": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string" },
    "completedAt": { "type": "string" },
    "status": { "enum": ["running", "passed", "failed", "blocked", "partial"] },
    "promptHash": { "type": "string" },
    "providerPolicy": { "type": "object", "required": ["provider"], "properties": { "provider": { "type": "string" }, "mode": { "enum": ["auto", "pinned", "fallback"] } } },
    "nodes": { "type": "array" },
    "artifacts": { "type": "array" },
    "evidenceSummary": {
      "type": "object",
      "required": ["required", "passed", "failed", "missing"],
      "properties": {
        "required": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "missing": { "type": "integer", "minimum": 0 }
      }
    },
    "decisionTracePath": { "type": "string" }
  }
}
