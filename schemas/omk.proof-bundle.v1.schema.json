{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-multi-agent-kit.dev/schemas/omk.proof-bundle.v1.schema.json",
  "title": "OMK Proof Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "proofId", "title", "omkVersion", "runtimeVersion", "commit", "runId", "providerPolicy", "scenario", "files", "verdict", "knownLimitations", "checksums"],
  "properties": {
    "schemaVersion": { "const": "omk.proof-bundle.v1" },
    "proofId": { "type": "string", "minLength": 1, "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "title": { "type": "string", "minLength": 1 },
    "omkVersion": { "type": "string", "minLength": 1 },
    "runtimeVersion": { "type": "string", "minLength": 1 },
    "commit": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "providerPolicy": { "type": "string", "minLength": 1 },
    "scenario": { "enum": ["no-kimi-smoke", "evidence-block", "fallback-route", "dag-dependent-block", "replay-inspect", "example-generation", "doctor-provider", "native-safety", "contract-version-smoke"] },
    "files": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 },
      "required": ["rawPrompt", "commands", "verifyJson", "decisionsJsonl", "runManifest", "evidenceJsonl", "limitations"]
    },
    "verdict": { "enum": ["passed", "failed", "partial"] },
    "knownLimitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "checksums": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
    }
  }
}
