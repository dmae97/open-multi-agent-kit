{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-multi-agent-kit.dev/schemas/omk.evidence-bundle.v1.schema.json",
  "title": "OMK Evidence Bundle",
  "type": "object",
  "required": ["schemaVersion", "runId", "commit", "provider", "runtimeVersion", "command", "changedFiles", "artifacts", "verifier", "redaction"],
  "properties": {
    "schemaVersion": { "const": "omk.evidence-bundle.v1" },
    "runId": { "type": "string", "minLength": 1 },
    "nodeId": { "type": "string", "minLength": 1 },
    "commit": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 },
    "runtimeVersion": { "type": "string", "minLength": 1 },
    "command": {
      "type": "object",
      "required": ["value", "exitCode"],
      "properties": {
        "value": { "type": "string", "minLength": 1 },
        "exitCode": { "type": "integer" }
      }
    },
    "changedFiles": { "type": "array", "items": { "type": "string" } },
    "diffHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "required": { "type": "boolean" },
          "kind": { "enum": ["file", "log", "diff", "metric", "review", "custom"] }
        }
      }
    },
    "verifier": {
      "type": "object",
      "required": ["verdict", "version"],
      "properties": {
        "verdict": { "enum": ["pass", "warn", "fail"] },
        "version": { "type": "string", "minLength": 1 },
        "checkedAt": { "type": "string" }
      }
    },
    "redaction": {
      "type": "object",
      "required": ["applied", "summary"],
      "properties": {
        "applied": { "type": "boolean" },
        "summary": { "type": "string", "minLength": 1 },
        "leakedSecretPatterns": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidenceRefs": { "type": "array" },
    "decisionRefs": { "type": "array" }
  }
}
