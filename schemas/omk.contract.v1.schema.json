{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-multi-agent-kit.dev/schemas/omk.contract.v1.schema.json",
  "title": "OMK JSON Envelope",
  "type": "object",
  "required": ["ok", "schemaVersion", "command", "omkVersion", "runtimeVersion", "traceId", "status", "data", "warnings", "errors", "metadata"],
  "properties": {
    "ok": { "type": "boolean" },
    "schemaVersion": { "const": "omk.contract.v1" },
    "command": { "type": "string", "minLength": 1 },
    "omkVersion": { "type": "string", "minLength": 1 },
    "runtimeVersion": { "const": "v1.2" },
    "commit": { "type": "string" },
    "runId": { "type": "string" },
    "traceId": { "type": "string", "minLength": 1 },
    "status": { "enum": ["passed", "failed", "blocked", "skipped", "partial", "dry-run", "not-applicable"] },
    "data": true,
    "warnings": { "type": "array" },
    "errors": { "type": "array" },
    "evidenceRefs": { "type": "array" },
    "decisionRefs": { "type": "array" },
    "metadata": {
      "type": "object",
      "required": ["cwd", "platform", "nodeVersion", "durationMs", "timestamp"],
      "properties": {
        "cwd": { "type": "string" },
        "platform": { "type": "string" },
        "nodeVersion": { "type": "string" },
        "provider": { "type": "string" },
        "durationMs": { "type": "number", "minimum": 0 },
        "timestamp": { "type": "string" }
      }
    }
  }
}
