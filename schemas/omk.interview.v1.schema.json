{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-multi-agent-kit.dev/schemas/omk.interview.v1.schema.json",
  "title": "OMK Deep Interview Session",
  "type": "object",
  "required": [
    "schemaVersion",
    "sessionId",
    "mode",
    "depth",
    "createdAt",
    "updatedAt",
    "ambiguity",
    "questions",
    "answers",
    "findings",
    "completeness",
    "specDelta",
    "status"
  ],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "const": "omk.interview.v1" },
    "sessionId": { "type": "string", "minLength": 1 },
    "goalId": { "type": "string" },
    "mode": { "enum": ["create", "refine"] },
    "depth": { "enum": ["light", "standard", "deep"] },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" },
    "rawPrompt": { "type": "string" },
    "ambiguity": { "type": "number", "minimum": 0, "maximum": 1 },
    "status": { "enum": ["open", "complete", "blocked"] },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "prompt", "required", "targetField", "score"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": {
            "enum": [
              "objective",
              "success-criteria",
              "artifact",
              "constraint",
              "non-goal",
              "risk",
              "authority",
              "evidence",
              "dependency",
              "rollback"
            ]
          },
          "prompt": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "targetField": {
            "enum": [
              "objective",
              "successCriteria",
              "expectedArtifacts",
              "constraints",
              "nonGoals",
              "risks",
              "riskLevel",
              "intentFrame",
              "actionAtoms"
            ]
          },
          "informationGain": { "type": "number", "minimum": 0, "maximum": 1 },
          "riskReduction": { "type": "number", "minimum": 0, "maximum": 1 },
          "dagImpact": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidenceImpact": { "type": "number", "minimum": 0, "maximum": 1 },
          "userCost": { "type": "number", "minimum": 0, "maximum": 1 },
          "score": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "answers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["questionId", "answer", "answeredAt"],
        "properties": {
          "questionId": { "type": "string", "minLength": 1 },
          "answer": { "type": "string" },
          "answeredAt": { "type": "string" },
          "skipped": { "type": "boolean" }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "value", "sourceQuestionId", "confidence"],
        "properties": {
          "field": { "type": "string", "minLength": 1 },
          "sourceQuestionId": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "conflict": { "type": "boolean" }
        }
      }
    },
    "completeness": {
      "type": "object",
      "required": ["overall", "criticalMissing", "contradictions"],
      "properties": {
        "overall": { "type": "number", "minimum": 0, "maximum": 1 },
        "objective": { "type": "number" },
        "successCriteria": { "type": "number" },
        "evidence": { "type": "number" },
        "artifacts": { "type": "number" },
        "constraints": { "type": "number" },
        "risks": { "type": "number" },
        "authority": { "type": "number" },
        "criticalMissing": { "type": "array", "items": { "type": "string" } },
        "contradictions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "specDelta": {
      "type": "object",
      "required": ["schemaVersion", "changes"],
      "properties": {
        "schemaVersion": { "const": "omk.interview-delta.v1" },
        "goalId": { "type": "string" },
        "changes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field", "op", "value", "sourceQuestionId", "confidence"],
            "properties": {
              "field": { "type": "string", "minLength": 1 },
              "op": { "enum": ["add", "replace", "remove"] },
              "sourceQuestionId": { "type": "string", "minLength": 1 },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        }
      }
    }
  }
}
