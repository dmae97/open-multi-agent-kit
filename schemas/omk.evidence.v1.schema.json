{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-multi-agent-kit.dev/schemas/omk.evidence.v1.schema.json",
  "title": "OMK Evidence Record",
  "type": "object",
  "required": ["schemaVersion", "runId", "evidenceId", "kind", "status", "required", "observedAt"],
  "properties": {
    "schemaVersion": { "const": "omk.evidence.v1" },
    "runId": { "type": "string", "minLength": 1 },
    "nodeId": { "type": "string" },
    "evidenceId": { "type": "string", "minLength": 1 },
    "kind": { "enum": ["file-exists", "command-passes", "git-diff-non-empty", "summary-present", "marker-present", "screenshot-present", "custom"] },
    "status": { "enum": ["passed", "failed", "missing", "skipped", "blocked"] },
    "required": { "type": "boolean" },
    "path": { "type": "string" },
    "command": { "type": "string" },
    "exitCode": { "type": "integer" },
    "observedAt": { "type": "string" },
    "message": { "type": "string" }
  }
}
