{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-multi-agent-kit.dev/schemas/omk.command.v1.schema.json",
  "title": "OMK Command Envelope",
  "type": "object",
  "required": ["schemaVersion", "command", "status", "startedAt", "finishedAt", "data", "diagnostics", "evidenceRefs", "exitCode"],
  "properties": {
    "schemaVersion": { "const": "omk.command.v1" },
    "command": { "type": "string", "minLength": 1 },
    "status": { "enum": ["pass", "warn", "fail"] },
    "runId": { "type": "string", "minLength": 1 },
    "commit": { "type": "string", "minLength": 1 },
    "startedAt": { "type": "string", "minLength": 1 },
    "finishedAt": { "type": "string", "minLength": 1 },
    "data": true,
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "code", "message", "redacted"],
        "properties": {
          "severity": { "enum": ["info", "warn", "error"] },
          "code": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 },
          "redacted": { "type": "boolean" },
          "remediation": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    },
    "evidenceRefs": { "type": "array" },
    "exitCode": { "type": "integer", "minimum": 0 }
  }
}
